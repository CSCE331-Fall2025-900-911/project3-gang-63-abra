# Backend API URL
# Use the hosted Vercel backend by default
# VITE_API_URL=https://abra-backend.vercel.app/api
# VITE_GOOGLE_URL=https://abra-backend.vercel.app/auth/google

# To use a local backend instead, uncomment the line below and comment out the line above:
VITE_API_URL=http://127.0.0.1:5000/api
VITE_GOOGLE_URL=http://127.0.0.1:5000/auth/google

